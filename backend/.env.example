# Paste the full service account JSON on one line (or use multiline JSON in docker-compose / panel secrets).
# Example (invalid — replace with your real key from Google Cloud):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

GOOGLE_SERVICE_ACCOUNT_JSON=

# From the sheet URL: .../spreadsheets/d/THIS_PART/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Optional: comma-separated extra origins for CORS (required origins are set in code).
# CORS_ALLOW_ORIGINS=http://localhost:3001
