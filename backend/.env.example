# Path to your service account JSON file (absolute path recommended on Windows)
SIWAKY_GOOGLE_CREDENTIALS_PATH=C:\path\to\your-service-account.json

# From the sheet URL: .../spreadsheets/d/THIS_PART/edit
SIWAKY_SPREADSHEET_ID=

# Tab name as it appears in the sheet footer (default first tab is usually Sheet1)
SIWAKY_SHEET_TAB=Sheet1
