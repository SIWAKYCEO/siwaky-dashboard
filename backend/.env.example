# --- Opzione consigliata se Easypanel mostra host / utente / password separati ---
# Incolla qui SOLO l'hostname o l'IP interno che vedi nella scheda Database (nessun URL completo).
# Il backend costruisce da solo postgres://… e lo prova prima dei fallback generici.
POSTGRES_HOST=
# POSTGRES_USER=siwaky
# POSTGRES_PASSWORD=siwaky
# POSTGRES_DB=siwaky
# POSTGRES_PORT=5432
# POSTGRES_SSLMODE=disable

# --- URL completo (se lo preferisci) ---
# DATABASE_URL=postgres://siwaky:siwaky@siwaky_database:5432/siwaky?sslmode=disable

# URL aggiuntivi separati da virgola se il DB è raggiungibile con più nomi
# DATABASE_URL_FALLBACKS=postgres://...

# Optional: comma-separated extra CORS origins (required hosts are set in code).
# CORS_ALLOW_ORIGINS=http://localhost:3001
