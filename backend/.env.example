# Web Push (VAPID) — dashboard background notifications
# Generate new keys for production (do not reuse examples):
#   python -c "from cryptography.hazmat.primitives.asymmetric import ec; from cryptography.hazmat.primitives import serialization; from cryptography.hazmat.backends import default_backend; import base64; k=ec.generate_private_key(ec.SECP256R1(), default_backend()); pem=k.private_bytes(serialization.Encoding.PEM, serialization.PrivateFormat.PKCS8, serialization.NoEncryption()).decode().replace('\n','\\n'); pub=k.public_key().public_bytes(serialization.Encoding.X962, serialization.PublicFormat.UncompressedPoint); print('VAPID_PRIVATE_KEY='+repr(pem)); print('VAPID_PUBLIC_KEY='+base64.urlsafe_b64encode(pub).decode().rstrip('='))"
# Or: npx web-push generate-vapid-keys  (paste both lines; keep private server-side only)

VAPID_EMAIL=siwaky.assistance@gmail.com

# PKCS8 EC private key (PEM) on one line — literal \n between PEM lines:
VAPID_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGHAgEAMBMGByqGSM49AgEGCCqGSM49AwEHBG0wawIBAQQgM4bogJtnhJogs01J\nuu6yv6gBu6lgqhVvjNfYxC3Z/nyhRANCAAQe/NdCKnpUiIM/pjDudqP5Ku2U9wG6\nA9GrB9irqCm7VWKeA8rkrl/RHUAx8qUIo2BA6M21bk5sjgQ2azk5svGa\n-----END PRIVATE KEY-----\n"

# Optional: if set, exposed to the browser for PushManager.subscribe (must match the private key).
# If unset, derived automatically from VAPID_PRIVATE_KEY.
VAPID_PUBLIC_KEY=BB7810IqelSIgz-mMO52o_kq7ZT3AboD0asH2KuoKbtVYp4DyuSuX9EdQDHypQijYEDozbVuTmyOBDZrOTmy8Zo

# Where JSON subscription + seen-order state files live (default: <repo>/backend/data/)
# PUSH_DATA_DIR=/app/data
