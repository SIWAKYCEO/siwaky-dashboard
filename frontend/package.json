{
  "name": "siwaky-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev": "next dev -p 3000",
    "dev:all": "concurrently -k -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev --prefix ../backend\"",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "generate:og": "node scripts/generate-og.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.11.10",
    "jose": "^6.2.3",
    "lucide-react": "^0.453.0",
    "next": "14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.15.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "jimp": "^1.6.1",
    "png-to-ico": "^2.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3"
  }
}
