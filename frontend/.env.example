# Dashboard (server-only; do not prefix with NEXT_PUBLIC_)
# JWT signing — min 32 characters. Image fallback exists; override in production.
DASHBOARD_AUTH_SECRET=

# Single admin login (plain comparison). Image defaults match dockerfile ENV.
DASHBOARD_ADMIN_EMAIL=siwaky.assistance@gmail.com
# If the password contains `#`, quote the value in shell / Compose: 'Siwaky#0317'
DASHBOARD_ADMIN_PASSWORD=

# FastAPI bridge for `/api/dashboard/orders` (server-side). Local dev:
DASHBOARD_ORDERS_API_BASE_URL=http://127.0.0.1:8000
# Optional alternate name (not NEXT_PUBLIC_API_URL — that is the public storefront API)
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
