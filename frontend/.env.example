# ── Dashboard (local dev) ───────────────────────────────────────────────
# JWT + users (required for `/dashboard` login)
DASHBOARD_AUTH_SECRET=replace-with-at-least-32-character-secret
# JSON array — see frontend/lib/dashboard/auth/users.ts for shape (passwordHash bcrypt recommended)
DASHBOARD_USERS_JSON=[{"email":"you@company.com","role":"admin","passwordHash":"$2a$12$..."}]
# DEV ONLY — never enable in production:
# DASHBOARD_AUTH_ALLOW_PLAINTEXT_PASSWORDS=true

# Orders proxy `/api/dashboard/orders` → FastAPI `GET /orders` (must be reachable FROM the Next process)
# Native dev (both on host): localhost is fine:
DASHBOARD_ORDERS_API_BASE_URL=http://127.0.0.1:8000
# Docker Compose frontend service: use the backend service URL instead — see docker-compose.yml
# DASHBOARD_ORDERS_API_BASE_URL=http://backend:8000
#
# Fallbacks if the above is unset (includes same name used by storefront):
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# ── Site (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
